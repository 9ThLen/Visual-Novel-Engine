  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.1.17",
    "@types/react-native": "^0.73.0",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.25.12",
    "esbuild-wasm": "^0.25.12",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.7.4",
    "qrcode": "^1.5.4",
