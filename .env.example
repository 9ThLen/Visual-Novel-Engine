# Cloud backup (optional).
#
# Leave these unset and the app runs entirely local-first: everything is stored
# in IndexedDB / the file system, and the Cloud section of Settings says so.
#
# Both values are safe to ship in a client bundle — the publishable key only
# grants what row-level security allows, and every backup policy is scoped to
# auth.uid(). Never put the service_role key here: it bypasses RLS.
#
# Copy to `.env`, then apply supabase/migrations/ to the project.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
