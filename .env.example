# Cloud backup (optional).
#
# Leave these unset and the app runs entirely local-first: everything is stored
# in IndexedDB / the file system, and the Cloud section of Settings says so.
#
# Both values are safe to ship in a client bundle — the publishable key only
# grants what row-level security allows, and every backup policy is scoped to
# auth.uid(). Never put the service_role key here: it bypasses RLS.
#
# Copy to `.env`, then apply supabase/migrations/ to the project.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# AI assistant bridge (optional).
#
# Without these, the editor's AI chat runs a scripted demo agent that only knows
# a few commands. Set a token to connect the real model through the local bridge
# (`pnpm ai-bridge`), which drives your Claude Code or Codex CLI.
#
# 1. Put the same random value in both keys below (`openssl rand -hex 24`).
# 2. The browser reads EXPO_PUBLIC_AI_BRIDGE_TOKEN; the bridge reads either key.
# 3. If your web dev server is NOT on port 8081, list its origin here too.
#
# The token only guards a 127.0.0.1 socket, so bundling EXPO_PUBLIC_AI_BRIDGE_TOKEN
# is safe. LAN exposure is a separate, later feature.
EXPO_PUBLIC_AI_BRIDGE_TOKEN=your-random-token
EXPO_PUBLIC_AI_BRIDGE_URL=ws://127.0.0.1:8787
# AI_BRIDGE_PROVIDER=claude   # or "codex"
# AI_BRIDGE_ALLOWED_ORIGINS=http://localhost:8092
