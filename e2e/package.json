{
  "testRunner": "detox",
  "runnerConfig": "e2e/config.json",
  "testTimeout": 120000,
  "setupFilesAfterEnv": ["./setup.ts"],
  "testMatch": ["**/__tests__/e2e/**/*.test.ts"],
  "detox": {
    "configurations": {
      "ios.sim.debug": {
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/visualnovel.app",
        "build": "xcodebuild -workspace ios/visualnovel.xcworkspace -scheme visualnovel -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build",
        "type": "ios.simulator",
        "device": {
          "type": "iPhone 14"
        }
      },
      "android.emu.debug": {
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug",
        "type": "android.emulator",
        "device": {
          "avdName": "Pixel_4_API_30"
        }
      }
    }
  }
}
