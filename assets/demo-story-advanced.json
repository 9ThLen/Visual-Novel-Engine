      "characters": [],
      "voiceAudioUri": null,
      "musicUri": "assets/sounds for sample/music-mysterious-adventure.mp3",
      "choices": [
        {
          "id": "choice_1s_1",
          "text": "Enter the museum",
          "nextSceneId": "scene_2"
        }
      ]
    },
