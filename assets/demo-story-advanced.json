    "scene_ending_true": {
      "id": "scene_ending_true",
      "text": "Congratulations! You've discovered the TRUE ENDING!\n\n✨ You collected all three legendary artifacts\n✨ You explored every corner of the museum\n✨ You proved yourself worthy\n\nThis demo showcased:\n• Splash screens (intro, chapter transitions, victory)\n• Interactive objects (signs, doors, pedestals, mirrors)\n• Inventory system (Crystal Key, Ancient Compass, Phoenix Feather)\n• Conditional actions (Phoenix Feather requires other items)\n• Multiple character sprites with positions\n• Background music and voice acting\n• Animated backgrounds (particles, shimmer, stars)\n• Branching narrative with multiple paths\n• Rich dialogue and storytelling\n\nThank you for playing! Now create your own amazing stories!",
      "backgroundImageUri": "assets/background/bg-treasure-chamber.png",
      "characters": [],
      "voiceAudioUri": null,
      "musicUri": "assets/sounds for sample/music-triumphant.mp3",
      "choices": [
